# secrets — NEVER commit
*.key
*.pem
*.seed
.env
secrets/
keys/

# data
*.db
*.sqlite
*.sqlite3
data/

# docker hub state bind-mounts. Anything the docker-compose file might
# create when COVE_STATE_DIR is a repo-relative path (./cove-state/,
# ./testbed-state/, etc). Keys + sqlite inside are already covered by
# rules above; this hides the top-level dirs from `git status` too.
/*-state/

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/

# os
.DS_Store
