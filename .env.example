# Cove hub — Docker Compose environment defaults.
#
# Copy this to `.env` (which is gitignored) to persist per-host settings,
# or pass the vars ad-hoc on the command line:
#
#     COVE_HUB_PORT=8001 COVE_STATE_DIR=./testbed-state \
#       docker compose up -d hub
#
# Vars are also honored by `docker compose --profile setup run bootstrap`
# — the ceremony writes into COVE_STATE_DIR so it and the hub agree on
# where state lives.

# Host port to bind the hub to. Container side is always 8000.
# Pick a free port when running a second hub on the same host
# (production LWCCOA hub on :8000, personal testbed on :8001, etc).
COVE_HUB_PORT=8000

# Host directory holding hub state (keys/, manifest.json, sqlite,
# blobs). Relative to the compose file if not absolute. Backup this
# directory to back up the hub.
COVE_STATE_DIR=./cove-state

# Docker container name. Change when running a second hub on the same
# host so `docker ps` / `docker logs` disambiguate cleanly.
COVE_CONTAINER_NAME=cove-hub

# Docker Compose project name. CRITICAL when running N hubs from one
# compose file: without this, both hubs share the default project
# (derived from the directory name), and any `docker compose up hub`
# recreates the shared service — destroying the other hub's container.
# Give each hub instance its own name so they're tracked independently.
COMPOSE_PROJECT_NAME=cove
